DASHSCOPE_API_KEY=your_alibaba_cloud_model_studio_api_key
ALIYUN_ASR_MODEL=paraformer-realtime-v2
ALIYUN_TTS_MODEL=cosyvoice-v3-flash
ALIYUN_TTS_VOICE=longanyang
ALIYUN_TTS_FORMAT=mp3

# Beijing region:
DASHSCOPE_WEBSOCKET_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference

# Optional online capture defaults:
ONLINE_PLAY_AUDIO=false
ONLINE_RECORD_SECONDS=0
ONLINE_RECORD_VIDEO=false
ONLINE_RECORD_CABIN_VIDEO=false
ONLINE_RECORD_UI_VIDEO=false
ONLINE_CAMERA_INDEX=0
ONLINE_VIDEO_FPS=20
ONLINE_CASE_PAUSE_SECONDS=0

# Singapore region:
# DASHSCOPE_WEBSOCKET_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference

# Optional aliases:
# ALIYUN_API_KEY=your_alibaba_cloud_model_studio_api_key
# ALIYUN_DASHSCOPE_API_KEY=your_alibaba_cloud_model_studio_api_key
# DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
# DASHSCOPE_TTS_MODEL=cosyvoice-v3-flash
# DASHSCOPE_TTS_VOICE=longanyang
# DASHSCOPE_TTS_FORMAT=mp3
